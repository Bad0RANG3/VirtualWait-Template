# Copy to /etc/virtualwait/gateway.env, chmod 0600, then replace every
# CHANGE_ME_* value with the matching production Web secret. This config uses
# the real HTTP provider adapter; the verifier URL must be an authorized service
# that exchanges/validates maimai QR codes and returns the documented JSON shape.
VW_GATEWAY_ENV=production
VW_GATEWAY_HOST=127.0.0.1
VW_GATEWAY_PORT=8787
VW_GATEWAY_DATABASE_PATH=/var/lib/virtualwait/gateway/gateway.db

VW_GATEWAY_KEY_ID=production-web-1
VW_GATEWAY_SHARED_SECRET=CHANGE_ME_PRODUCTION_GATEWAY_SHARED_SECRET_64_HEX
VW_PUBLIC_ID_HMAC_SECRET=CHANGE_ME_PRODUCTION_PUBLIC_ID_HMAC_SECRET_64_HEX

# Production default: operator-owned HTTP verifier.
# For SDGB no-login preview (AiMe + GetUserPreviewApi), set
# VW_GATEWAY_PROVIDER=sdgb_preview and the VW_SDGB_* values instead.
VW_GATEWAY_PROVIDER=http
VW_GATEWAY_HTTP_VERIFY_URL=https://verifier.example.com/v1/maimai/verify-qr
VW_GATEWAY_HTTP_AUTH_HEADER=Authorization
VW_GATEWAY_HTTP_AUTH_VALUE=Bearer CHANGE_ME_PRODUCTION_PROVIDER_AUTH_TOKEN_64_HEX
VW_GATEWAY_HTTP_TIMEOUT_SEC=10

VW_GATEWAY_MAX_CONCURRENT=3
VW_GATEWAY_RATE_LIMIT_PER_MINUTE=40
VW_GATEWAY_CLOCK_SKEW_SEC=300
VW_GATEWAY_NONCE_TTL_SEC=600
VW_GATEWAY_RECOVERY_INTERVAL_SEC=5
