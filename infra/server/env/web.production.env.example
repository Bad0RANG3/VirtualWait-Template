# Copy to /etc/virtualwait/web.env, chmod 0600, then replace every CHANGE_ME_*
# value with a unique production secret. Do not reuse staging values.
# The Web production preflight must pass before enabling the service. The real
# Gateway/provider is still a separate release gate documented in docs/.
NODE_ENV=production
APP_BASE_URL=https://wait.example.com
VIRTUALWAIT_DATA_DIR=/var/lib/virtualwait/web
VIRTUALWAIT_BACKUP_DIR=/var/backups/virtualwait

SESSION_MAX_AGE_DAYS=30
SESSION_SECRET=CHANGE_ME_PRODUCTION_SESSION_SECRET_64_HEX
PUBLIC_ID_HMAC_SECRET=CHANGE_ME_PRODUCTION_PUBLIC_ID_HMAC_SECRET_64_HEX
ADMIN_API_TOKEN=CHANGE_ME_PRODUCTION_ADMIN_API_TOKEN_64_HEX

GATEWAY_MODE=remote
GATEWAY_BASE_URL=http://127.0.0.1:8787
GATEWAY_KEY_ID=production-web-1
GATEWAY_SHARED_SECRET=CHANGE_ME_PRODUCTION_GATEWAY_SHARED_SECRET_64_HEX
GATEWAY_TIMEOUT_MS=15000

TRUST_PROXY_HEADERS=true
QR_MAX_CONCURRENT=3
QR_LOGIN_IP_LIMIT=8
QR_LOGIN_IP_WINDOW_SEC=300
QR_LOGIN_GLOBAL_LIMIT=40
QR_LOGIN_GLOBAL_WINDOW_SEC=60
AUTH_ATTEMPT_POLL_LIMIT=30
AUTH_ATTEMPT_POLL_WINDOW_SEC=60

PLAYING_TIMEOUT_SEC=1500
HEAD_CONFIRM_TIMEOUT_SEC=180

MAINTENANCE_INTERVAL_SEC=15
TRANSIENT_DATA_RETENTION_SEC=86400
RATE_LIMIT_BUCKET_RETENTION_SEC=3600
IP_BINDING_RETENTION_DAYS=2
PROFILE_DATA_RETENTION_DAYS=180
QUEUE_HISTORY_RETENTION_DAYS=180
AUDIT_EVENT_RETENTION_DAYS=365
