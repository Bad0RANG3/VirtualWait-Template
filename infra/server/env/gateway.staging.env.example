# Copy to /etc/virtualwait-staging/gateway.env, chmod 0600, then replace every
# CHANGE_ME_* value with the matching staging Web secret. This mock/test Gateway
# is suitable for staging flow checks only; it is not a real SDGB provider.
VW_GATEWAY_ENV=test
VW_GATEWAY_HOST=127.0.0.1
VW_GATEWAY_PORT=8787
VW_GATEWAY_DATABASE_PATH=/var/lib/virtualwait-staging/gateway/gateway.db

VW_GATEWAY_KEY_ID=staging-web-1
VW_GATEWAY_SHARED_SECRET=CHANGE_ME_STAGING_GATEWAY_SHARED_SECRET_64_HEX
VW_PUBLIC_ID_HMAC_SECRET=CHANGE_ME_STAGING_PUBLIC_ID_HMAC_SECRET_64_HEX

VW_GATEWAY_PROVIDER=mock
VW_GATEWAY_MAX_CONCURRENT=2
VW_GATEWAY_RATE_LIMIT_PER_MINUTE=30
VW_GATEWAY_CLOCK_SKEW_SEC=300
VW_GATEWAY_NONCE_TTL_SEC=600
VW_GATEWAY_RECOVERY_INTERVAL_SEC=5

# Optional: VW_GATEWAY_PROVIDER=sdgb_preview with VW_SDGB_* settings
