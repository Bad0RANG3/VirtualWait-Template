[Unit]
Description=VirtualWait SQLite backup
After=virtualwait-web.service

[Service]
Type=oneshot
User=virtualwait
Group=virtualwait
WorkingDirectory=/opt/virtualwait/apps/web
EnvironmentFile=/etc/virtualwait/web.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run db:backup
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/virtualwait/web /var/backups/virtualwait
