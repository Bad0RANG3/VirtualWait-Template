{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virtualwait.local/schemas/public-profile.json",
  "title": "PublicMaimaiProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["displayName"],
  "properties": {
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "rating": { "type": ["integer", "null"], "minimum": 0, "maximum": 30000 },
    "title": { "type": ["string", "null"], "maxLength": 200 },
    "iconUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2048 }
  }
}
