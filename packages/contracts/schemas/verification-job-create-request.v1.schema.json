{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virtualwait.local/schemas/verification-job-create-request.v1.json",
  "title": "CreateVerificationJobRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["qrCode", "requestedPublicFields"],
  "properties": {
    "qrCode": { "type": "string", "minLength": 4, "maxLength": 2048 },
    "requestedPublicFields": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["displayName", "rating", "title"]
      }
    }
  }
}
