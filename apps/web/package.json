{
  "name": "virtualwait-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite next dev",
    "build": "NODE_OPTIONS=--experimental-sqlite next build",
    "start": "NODE_OPTIONS=--experimental-sqlite next start",
    "lint": "eslint .",
    "test": "tsx --test src/lib/gateway/contracts.test.ts src/lib/auth/ip.test.ts src/lib/queue/maintenance.test.ts src/lib/env.test.ts src/lib/api.test.ts src/lib/constants/catalog.test.ts src/lib/queue/head-timeout.test.ts src/lib/queue/bot.test.ts src/lib/queue/join-qq.test.ts",
    "test:e2e": "node scripts/e2e.mjs",
    "test:browser": "playwright test",
    "preflight": "node scripts/preflight.mjs",
    "maintenance": "NODE_OPTIONS=--experimental-sqlite tsx scripts/maintenance.ts",
    "healthcheck": "node scripts/healthcheck.mjs",
    "db:backup": "NODE_OPTIONS=--experimental-sqlite tsx scripts/backup-db.ts",
    "db:verify": "NODE_OPTIONS=--experimental-sqlite tsx scripts/verify-backup-db.ts",
    "db:reset": "node scripts/reset-db.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.525.0",
    "next": "^15.5.20",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "^0.35.0"
  }
}
