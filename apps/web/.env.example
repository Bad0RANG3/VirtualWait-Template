# Template placeholder. Replace locally; production requires a unique random value.
SESSION_SECRET=CHANGE_ME_DEVELOPMENT_SESSION_SECRET
# User login cookie lifetime. Set higher to keep users logged in longer.
SESSION_MAX_AGE_DAYS=30

# Optional absolute path for SQLite runtime data. Defaults to ./data.
# VIRTUALWAIT_DATA_DIR=/var/lib/virtualwait/web
# Optional directory used when `npm run db:backup` is run without --output.
# VIRTUALWAIT_BACKUP_DIR=/var/backups/virtualwait

# HMAC for deriving a public identity without storing a raw upstream user ID.
PUBLIC_ID_HMAC_SECRET=CHANGE_ME_DEVELOPMENT_PUBLIC_ID_HMAC_SECRET

# Web always uses the signed Gateway contract.
# Local offline fixtures are provided by Gateway VW_GATEWAY_PROVIDER=mock
# with mock:* QR values (not an in-process Web shortcut).
GATEWAY_MODE=remote

# Production allows HTTPS, or this private same-host loopback URL;
# arbitrary remote HTTP is rejected.
GATEWAY_BASE_URL=http://127.0.0.1:8787
GATEWAY_KEY_ID=template-web-1
GATEWAY_SHARED_SECRET=CHANGE_ME_DEVELOPMENT_GATEWAY_SHARED_SECRET
# Production: unique random string, at least 32 chars. Required even if the
# admin API is not publicly linked, so it cannot be silently left open.
ADMIN_API_TOKEN=CHANGE_ME_DEVELOPMENT_ADMIN_API_TOKEN
# Optional: AstrBot queue-notify bot token (Bearer). Leave empty to disable /api/bot/*.
BOT_API_TOKEN=
BOT_CATALOG_RATE_LIMIT=20
BOT_QUEUE_RATE_LIMIT=120
GATEWAY_TIMEOUT_MS=15000

# Queue timing (seconds)
PLAYING_TIMEOUT_SEC=1500
# Head-of-queue must confirm start within this many seconds.
# 1st miss: move one group back. 2nd miss: auto cancel (unload).
HEAD_CONFIRM_TIMEOUT_SEC=180

# Abuse protection
# Production must be deployed behind a proxy that strips client-supplied
# X-Forwarded-For / X-Real-IP and writes the verified client IP itself.
# Set to true only for that configuration. It is required in production.
TRUST_PROXY_HEADERS=false
QR_MAX_CONCURRENT=3
QR_LOGIN_IP_LIMIT=8
QR_LOGIN_IP_WINDOW_SEC=300
QR_LOGIN_GLOBAL_LIMIT=40
QR_LOGIN_GLOBAL_WINDOW_SEC=60
AUTH_ATTEMPT_POLL_LIMIT=30
AUTH_ATTEMPT_POLL_WINDOW_SEC=60

# Maintenance worker (can be run with `npm run maintenance`)
MAINTENANCE_INTERVAL_SEC=15
TRANSIENT_DATA_RETENTION_SEC=86400
# Expired fixed-window counters contain only keyed/IP-derived bucket keys.
RATE_LIMIT_BUCKET_RETENTION_SEC=3600
# Privacy retention policy. The maintenance worker removes old daily IP bindings,
# scrubs inactive profile/IP metadata, and deletes terminal queue/audit history.
IP_BINDING_RETENTION_DAYS=2
PROFILE_DATA_RETENTION_DAYS=180
QUEUE_HISTORY_RETENTION_DAYS=180
AUDIT_EVENT_RETENTION_DAYS=365

# 站点对外 origin（生产必填）。推荐 HTTPS；受控内网/测试部署可使用 HTTP。
# 例如 https://wait.example.com 或 http://wait.example.com
APP_BASE_URL=

# Optional path to a system Chromium binary for Playwright browser tests.
# Omit it when using `npx playwright install chromium`.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE=/usr/bin/chromium
