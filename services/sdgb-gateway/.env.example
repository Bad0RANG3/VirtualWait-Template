# Local development defaults. Mock accepts only mock:* QR fixtures.
VW_GATEWAY_ENV=development
VW_GATEWAY_HOST=127.0.0.1
VW_GATEWAY_PORT=8787
VW_GATEWAY_DATABASE_PATH=./data/gateway.db

# Must match the Web configuration when Web uses GATEWAY_MODE=remote.
VW_GATEWAY_KEY_ID=template-web-1
VW_GATEWAY_SHARED_SECRET=CHANGE_ME_DEVELOPMENT_GATEWAY_SHARED_SECRET
VW_PUBLIC_ID_HMAC_SECRET=CHANGE_ME_DEVELOPMENT_PUBLIC_ID_HMAC_SECRET

# Use mock for offline tests.
# http = operator-owned verifier HTTP adapter.
# sdgb_preview = no-login AiMe QR exchange + GetUserPreviewApi (no UserLoginApi).
VW_GATEWAY_PROVIDER=mock
# VW_GATEWAY_HTTP_VERIFY_URL=https://verifier.example.com/v1/maimai/verify-qr
# VW_GATEWAY_HTTP_AUTH_HEADER=Authorization
# VW_GATEWAY_HTTP_AUTH_VALUE=Bearer CHANGE_ME_PROVIDER_TOKEN
# VW_GATEWAY_HTTP_TIMEOUT_SEC=10

# SDGB no-login preview provider (only when VW_GATEWAY_PROVIDER=sdgb_preview)
# VW_SDGB_AIME_URL=http://ai.sys-allnet.cn/wc_aime/api/get_data
# VW_SDGB_TITLE_SERVER_URL=https://maimai-gm.wahlap.com:42081/Maimai2Servlet
# VW_SDGB_AIME_SALT=CHANGE_ME_AIME_SALT
# VW_SDGB_AES_KEY=CHANGE_ME_AES_KEY
# VW_SDGB_AES_IV=CHANGE_ME_AES_IV
# VW_SDGB_OBFUSCATE_PARAM=CHANGE_ME_OBFUSCATE
# VW_SDGB_KEYCHIP_ID=A63E-01XXXXXXXXXXX
# VW_SDGB_CLIENT_ID=A63E01XXXXX
# VW_SDGB_TIMEOUT_SEC=10

VW_GATEWAY_MAX_CONCURRENT=3
VW_GATEWAY_RATE_LIMIT_PER_MINUTE=40
VW_GATEWAY_CLOCK_SKEW_SEC=300
VW_GATEWAY_NONCE_TTL_SEC=600
VW_GATEWAY_RECOVERY_INTERVAL_SEC=5
